#include <stdio.h>

int main(){
    int i, j;

    for( i = 1; i <= 9; i++){  //outer loop

        for( j = 1; j <= i; j++){  //inner loop

            printf("%d", i);
        }
        printf("\n");
    }
    for( i = 8; i >= 1; i--){  //outer loop

        for( j = 1; j <= i; j++){  //inner loop

            printf("%d", i);
        }
        printf("\n");
    }

}